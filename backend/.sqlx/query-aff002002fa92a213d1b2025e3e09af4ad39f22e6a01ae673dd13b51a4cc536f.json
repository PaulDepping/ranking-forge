{
  "db_name": "PostgreSQL",
  "query": "SELECT pm.project_id, pm.user_id, u.username,\n                  pm.role as \"role: ProjectMemberRole\", pm.joined_at\n           FROM project_members pm\n           JOIN users u ON u.id = pm.user_id\n           WHERE pm.project_id = $1\n           ORDER BY pm.joined_at ASC",
