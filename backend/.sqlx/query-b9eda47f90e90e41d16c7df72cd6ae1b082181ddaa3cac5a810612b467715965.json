  "query": "\n        SELECT e.id, e.startgg_id, e.name, e.game_name, e.num_entrants,\n               e.start_at, pe.included\n        FROM events e\n        JOIN project_events pe ON pe.event_id = e.id AND pe.project_id = $1\n        WHERE e.id = $2\n        ",
