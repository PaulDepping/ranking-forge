  "query": "SELECT pm.project_id, pm.user_id, u.display_name,\n                  pm.role as \"role: MemberRole\", pm.joined_at\n           FROM project_members pm\n           JOIN users u ON u.id = pm.user_id\n           WHERE pm.project_id = $1\n           ORDER BY pm.joined_at ASC",
