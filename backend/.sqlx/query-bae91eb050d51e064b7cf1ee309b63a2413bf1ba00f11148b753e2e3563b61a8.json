  "query": "SELECT rp.player_id, pl.name, rp.rank_position, rp.notes\n         FROM ranking_players rp\n         JOIN players pl ON pl.id = rp.player_id\n         WHERE rp.ranking_id = $1\n         ORDER BY rp.rank_position ASC, pl.created_at ASC",
